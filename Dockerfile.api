# Stage 1: Build
FROM node:20-slim AS builder

WORKDIR /app

# Copy entire workspace
COPY . .

# Use npx pnpm to install and build
RUN npx pnpm install
RUN npx pnpm -F @workspace/api-server build

# Stage 2: Runtime
FROM node:20-slim

WORKDIR /app

# Copy entire workspace from builder
COPY --from=builder /app .

# Expose API port
EXPOSE 8000

# Start API server
CMD ["npx", "pnpm", "-F", "@workspace/api-server", "start"]
